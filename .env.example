# .env (Template)
SEC_API_KEY=your_sec_api_key_here          # Get from: https://sec-api.io/ (Register for a free API key)
APIFY_API_TOKEN=your_apify_token_here      # Get from: https://console.apify.com/ (Sign up for an Apify account and go to Settings > Integrations)
OPENROUTER_API_KEY=your_openrouter_key_here# Get from: https://openrouter.ai/keys (Sign up and create a key)

# Models
OPENROUTER_MODEL_CHAT=openrouter/auto      # Default chat model for ChatAgent. Replace if you prefer a specific one (e.g. anthropic/claude-3-opus)
OPENROUTER_MODEL_CLASSIFY=mistralai/mixtral-8x7b-instruct # Recommended model for Sentiment classification (cheap & fast).

# LightRAG Configuration
LIGHTRAG_STORAGE_BACKEND=networkx          # Use 'networkx' for local dev, switch to 'neo4j'/'postgresql' in prod
LIGHTRAG_LLM_MODEL=openrouter/auto         # LLM model for Entity Extraction inside LightRAG
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-small # Text embedding model for vector DB (supports OpenAI through OpenRouter)

# Database
DB_TYPE=duckdb                             # Use 'duckdb' for local file-based DB, 'postgresql' for prod
DB_PATH=./data/insider_trading.duckdb      # Local path to store duckdb database file

# System Scheduling & Parameters
POLLING_INTERVAL_MINUTES=30                # Ingestion pipeline cron schedule (every X minutes)
TOP_N_TRADES=5                             # Number of trades RankingAgent should pick in its top N list
TWEET_LOOKBACK_DAYS=7                      # Number of days the SocialScraperAgent should look back for tweets